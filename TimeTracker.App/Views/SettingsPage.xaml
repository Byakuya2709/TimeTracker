<UserControl x:Class="TimeTracker.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/MainWindowStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
<Grid Visibility="{Binding IsSettingsPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" 
                                Background="White" 
                                Padding="28" 
                                CornerRadius="16"
                                BorderBrush="#EAEAEA"
                                BorderThickness="1">

                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="25" ShadowDepth="4" Opacity="0.06" Color="Black"/>
                                </Border.Effect>

                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#3E4942"
                                               Margin="0,0,0,8"
                                               Text="TÙY CHỌN THEO DÕI"/>

                                    <StackPanel Margin="0,16,0,0">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#1A1C1C" Text="Thời gian phát hiện không hoạt động"/>
                                        <TextBlock Style="{StaticResource ModernDescriptionTextStyle}" Text="Tự động dừng tính giờ sau một khoảng thời gian chờ."/>

                                        <UniformGrid Columns="2" Margin="0,16,0,0">
                                            <Button Margin="0,0,6,0"
                        Command="{Binding SetIdleDetection5Command}"
                        Tag="{Binding IsIdleDetection5Selected}"
                        Style="{StaticResource ModernOptionButtonStyle}"
                        Content="5 phút"/>
                                            <Button Margin="6,0,0,0"
                        Command="{Binding SetIdleDetection10Command}"
                        Tag="{Binding IsIdleDetection10Selected}"
                        Style="{StaticResource ModernOptionButtonStyle}"
                        Content="10 phút"/>
                                        </UniformGrid>
                                    </StackPanel>

                                    <Separator Background="#F0F0F0" Margin="0,24" Height="1"/>

                                    <DockPanel LastChildFill="False">
                                        <StackPanel DockPanel.Dock="Left">
                                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#1A1C1C" Text="Tự khởi động cùng Windows"/>
                                            <TextBlock Style="{StaticResource ModernDescriptionTextStyle}" Text="Mở ứng dụng ngay khi bạn đăng nhập."/>
                                        </StackPanel>

                                        <Button DockPanel.Dock="Right"
                    Width="60"
                    VerticalAlignment="Center"
                    Tag="{Binding AutoStartOnBoot}"
                    Command="{Binding ToggleAutoStartCommand}"
                    Style="{StaticResource ModernToggleButtonStyle}"
                    Content="{Binding AutoStartOnBootStateText}"/>
                                    </DockPanel>

                                    <Separator Background="#F0F0F0" Margin="0,24" Height="1"/>

                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock DockPanel.Dock="Left" FontSize="14" FontWeight="SemiBold" Foreground="#1A1C1C" Text="Độ mờ lớp phủ - Overlay"/>

                                            <Border DockPanel.Dock="Right" Background="#E8F5E9" CornerRadius="4" Padding="8,3" BorderBrush="#C8E6C9" BorderThickness="1">
                                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="#006947" Text="{Binding OverlayOpacityText}"/>
                                            </Border>
                                        </DockPanel>

                                        <Slider Style="{StaticResource ModernSlider}"
                    Margin="0,16,0,0"
                    Minimum="10"
                    Maximum="100"
                    Value="{Binding OverlayOpacity}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Background="#F3F3F3" Padding="24" BorderBrush="#E3E8DF">
                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="Bold" Foreground="#3E4942"
                                               TextWrapping="Wrap"
                                               Text="VỊ TRÍ HIỂN THỊ LỚP PHỦ - OVERLAY"/>
                                    <UniformGrid Margin="0,16,0,0" Columns="3" Rows="3">
                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,6,6" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsTopLeftOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.TopLeft}">
                                            <materialDesign:PackIcon Kind="ArrowTopLeft" Width="18" Height="18"/>
                                        </RadioButton>
                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,6,6" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsTopCenterOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.TopCenter}">

                                        <materialDesign:PackIcon Kind="ArrowTop" Width="18" Height="18"/>
                                        </RadioButton>


                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,0,6" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsTopRightOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.TopRight}">
                                        <materialDesign:PackIcon Kind="ArrowTopRight" Width="18" Height="18"/>
                                        </RadioButton>
                                        

                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,6,6" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsMiddleLeftOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.MiddleLeft}">
                                        <materialDesign:PackIcon Kind="ArrowLeft" Width="18" Height="18"/>
                                        </RadioButton>


                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,6,6" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsCenterOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.Center}">
                                            <materialDesign:PackIcon Kind="Dot" Width="40" Height="40"/>
                                        </RadioButton>
                                        
                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,0,6" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsMiddleRightOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.MiddleRight}">
                                            <materialDesign:PackIcon Kind="ArrowRight" Width="18" Height="18"/>
                                        </RadioButton>
                                        
                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,6,0" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsBottomLeftOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.BottomLeft}">
                                            <materialDesign:PackIcon Kind="ArrowBottomLeft" Width="18" Height="18"/>
                                        </RadioButton>

                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,6,0" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsBottomCenterOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.BottomCenter}">
                                            <materialDesign:PackIcon Kind="ArrowBottom" Width="18" Height="18"/>
                                        </RadioButton>

                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,0,0" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsBottomRightOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.BottomRight}">
                                            <materialDesign:PackIcon Kind="ArrowBottomRight" Width="18" Height="18"/>
                                        </RadioButton>
                                    </UniformGrid>

                                    <Border Margin="0,18,0,0" Background="#FFFFFF" BorderBrush="#DCE6D8" BorderThickness="1" CornerRadius="10" Padding="12">
                                        <StackPanel>
                                            <TextBlock FontSize="12" Foreground="DarkRed" Text="Mẹo"/>
                                            <TextBlock Margin="0,6,0,0" FontSize="13" FontWeight="Medium" Foreground="#1E3324" 
                                                       TextWrapping="Wrap"
                                                       Text="Chọn vị trí ít ảnh hưởng đến nội dung công việc của bạn nhất."/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
</UserControl>
