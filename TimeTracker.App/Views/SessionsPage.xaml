<UserControl x:Class="TimeTracker.App.Views.SessionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
                <UserControl.Resources>
                    <ResourceDictionary>
                        <ResourceDictionary.MergedDictionaries>
                            <ResourceDictionary Source="../Styles/DatePicker.xaml"/>
                            <ResourceDictionary Source="../Styles/MainWindowStyles.xaml"/>
                        </ResourceDictionary.MergedDictionaries>
                    </ResourceDictionary>
                </UserControl.Resources>
                <Grid Visibility="{Binding IsSessionsPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,14" VerticalAlignment="Center">
                                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                    <StackPanel Margin="0,0,0,0" Orientation="Horizontal">
                                        <Border Background="#E8F1E4" CornerRadius="10" Padding="2,3">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#2E5037" Text="Chu kì theo dõi"/>
                                        </Border>
                                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="#4A5B48" Text="{Binding WeekRangeTitle}"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <DatePicker 
                                        Style="{StaticResource ModernDatePicker}"
                                        SelectedDate="{Binding SelectedWeekDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Width="100" Height="34" Margin="0,0,8,0" Style="{StaticResource SessionActionButtonStyle}" Foreground="White" Command="{Binding RefreshSessionsCommand}" Content="Làm mới"/>
                                    <Button Width="146" Height="34" Style="{StaticResource SessionActionButtonStyle}" Background="DarkRed" BorderBrush="#D8C0C0" Foreground="White" Command="{Binding DeleteSelectedSessionCommand}" Content="Xóa mục chọn"/>
                                </StackPanel>
                            </DockPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SessionShellStyle}" Padding="12">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="25" ShadowDepth="4" Opacity="0.06" Color="Black"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <Grid>
                                            <ItemsControl ItemsSource="{Binding SessionDayGroups}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,12" Padding="10">
                                                        <StackPanel>
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#24422A" Text="{Binding DateTitle}"/>
                                                                <Border DockPanel.Dock="Right" Background="#E6EFE2" CornerRadius="8" Padding="8,2">
                                                                    <TextBlock Style="{StaticResource SessionMetaTextStyle}" FontWeight="SemiBold" Text="{Binding Sessions.Count, StringFormat={}{0} phiên}"/>
                                                                </Border>
                                                            </DockPanel>

                                                            <ItemsControl ItemsSource="{Binding Sessions}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Button Margin="0,8,0,0"
                                                                                Style="{StaticResource SessionItemButtonStyle}"
                                                                                Tag="{Binding IsSelected}"
                                                                                Command="{Binding DataContext.SelectTrackingSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="4"/>
                                                                                    <ColumnDefinition Width="8"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>

                                                                                <Border Grid.Column="0"
                                                                                        Background="#4E7F59"
                                                                                        CornerRadius="2"
                                                                                        Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                                <StackPanel Grid.Column="2">
                                                                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1D3022" Text="{Binding TimeRange}"/>
                                                                                    <TextBlock Margin="0,2,0,0" FontSize="12" Foreground="#4B6148" Text="{Binding TopApps}" TextWrapping="Wrap"/>
                                                                                </StackPanel>

                                                                                <StackPanel Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Center">
                                                                                    <Border HorizontalAlignment="Right" Background="#EAF2E7" CornerRadius="8" Padding="8,2">
                                                                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#24422A" Text="{Binding TotalDuration}"/>
                                                                                    </Border>
                                                           
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                            <TextBlock Text="Không có dữ liệu."
                                                        FontSize="14"
                                                       Foreground="#6A7A67"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">                                  
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SessionDayGroups.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                          
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            
                                        </Grid>

                                    </ScrollViewer>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource SessionShellStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                 
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#1E3324" Text="Chi tiết phiên theo dõ"/>
                                        

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,12,0,0"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1D3022"
                                                   Text="{Binding SelectedTrackingSession.SessionDateTitle}"
                                                   Visibility="{Binding HasSelectedTrackingSession, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                        <TextBlock Grid.Row="2"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="#50634E"
                                                   Text="{Binding SelectedTrackingSession.TimeRange, StringFormat=Từ: {0}}"
                                                   Visibility="{Binding HasSelectedTrackingSession, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                        <Grid Grid.Row="3" Margin="0,12,0,0" Visibility="{Binding HasSelectedTrackingSession, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <UniformGrid Grid.Row="0" Columns="2" Margin="0,0,0,12">
                                                <Border Margin="0,0,8,0" Background="#F1F7EE" BorderBrush="#D8E5D4" BorderThickness="1" CornerRadius="10" Padding="10,8">
                                                    <StackPanel>
                                                        <TextBlock FontSize="11" Foreground="#60715E" Text="Tổng"/>
                                                        <TextBlock Margin="0,2,0,0" FontSize="14" FontWeight="SemiBold" Foreground="#1D3022" Text="{Binding SelectedTrackingSession.TotalDuration}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="#F8F6EC" BorderBrush="#E6DDC8" BorderThickness="1" CornerRadius="10" Padding="10,8">

                                                    <StackPanel>
                                                        <TextBlock FontSize="11" Foreground="#6D6A54" Text="Không hoạt động"/>
                                                        <TextBlock Margin="0,2,0,0" FontSize="14" FontWeight="SemiBold" Foreground="#3F3A20" Text="{Binding SelectedTrackingSession.IdleDuration}"/>
                                                    </StackPanel> 
                                                </Border>
                                            </UniformGrid>


                                            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                                <TextBlock  FontSize="16" FontWeight="SemiBold" Foreground="#24422A" Text="Chi tiết"/>
                                                <TextBlock Style="{StaticResource ModernDescriptionTextStyle}" Text="Thời gian sử dụng của từng ứng dụng"/>
                                            </StackPanel>
                                            
                                       
                                            <Border Grid.Row="2" Grid.RowSpan="2" Margin="0,8,0,0" Background="#F7FBF5" BorderBrush="#DCE6D8" BorderThickness="1" CornerRadius="10" Padding="10">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding SelectedTrackingSession.AppUsageProgressItems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="0,0,0,10">
                                                                    <DockPanel LastChildFill="False">
                                                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#24422A" Text="{Binding AppName}"/>
                                                                        <TextBlock DockPanel.Dock="Right" FontSize="11" Foreground="#536651" Text="{Binding Duration}"/>
                                                                    </DockPanel>
                                                                    <Grid Margin="0,6,0,0">
                                                                        <ProgressBar Height="8"
                                                                                     Minimum="0"
                                                                                     Maximum="100"
                                                                                     Value="{Binding Percent}"
                                                                                     Background="#E5EDE2"
                                                                                     Foreground="#4F7E59">
                                                                            <ProgressBar.Template>

                                                                                <ControlTemplate TargetType="ProgressBar">
                                                                                    <Border Background="#E5EDE2" CornerRadius="4" Height="8">
                                                                                        <Border x:Name="PART_Track" Background="#4F7E59" CornerRadius="4"/>
                                                                                    </Border>
                                                                                </ControlTemplate>
                                                                            </ProgressBar.Template>

                                                                        </ProgressBar>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="3"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="#60715E"
                                                   Text="Chọn một phiên để xem chi tiết."
                                                   Visibility="{Binding NoSelectedTrackingSession, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border Grid.Row="2" Margin="0,10,0,0" Background="#EEF4EA" BorderBrush="#D7E2D2" BorderThickness="1" CornerRadius="10" Padding="10,7">
                                <TextBlock FontSize="12" Foreground="#3F5645" Text="{Binding SessionsStatusMessage}"/>
                            </Border>
                        </Grid>

                        
</UserControl>
