<Window x:Class="TimeTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Bảng điều khiển TimeTracker"
        Width="1240"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        FontFamily="pack://application:,,,/TimeTracker.App;component/Resourses/Assets/Fonts/#Inter"
        Background="#E7EDE1">


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="252"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1F3724">
            <Grid Margin="18,24,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="#F3FAEF" Text="TimeTracker"/>
                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="#C9DFC6" Text="Bảng điều khiển tập trung cá nhân"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,30,0,0">
                    <RadioButton GroupName="SidebarTabs"
                                 Margin="0,0,0,10"
                                 IsChecked="{Binding IsOverviewPage, Mode=OneWay}"
                                 Command="{Binding ShowOverviewCommand}"
                                 Style="{StaticResource ControlButtonStyle}">

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon 
                            Kind="Settings"
                            Width="18"
                            Height="18"
                            Margin="0,0,8,0"
                            Foreground="White"/>

                            <TextBlock 
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#F3FAEF"
                                Text="Tổng quan"/>
                        </StackPanel>

                    </RadioButton>

                    <RadioButton GroupName="SidebarTabs"
                                 Margin="0,0,0,10"
                                 IsChecked="{Binding IsSessionsPage, Mode=OneWay}"
                                 Command="{Binding ShowSessionsCommand}"
                                 Style="{StaticResource ControlButtonStyle}">


                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon 
                                    Kind="History"
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    Foreground="White"/>

                            <TextBlock 
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#F3FAEF"
                                Text="Lịch sử"/>
                        </StackPanel>

                    </RadioButton>

                    <RadioButton GroupName="SidebarTabs"
                                 IsChecked="{Binding IsSettingsPage, Mode=OneWay}"
                                 Command="{Binding ShowSettingsCommand}"
                                 Style="{StaticResource ControlButtonStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon 
                     Kind="Settings"
                     Width="18"
                     Height="18"
                     Margin="0,0,8,0"
                     Foreground="White"/>

                            <TextBlock 
                 FontSize="14"
                 FontWeight="SemiBold"
                 Foreground="#F3FAEF"
                 Text="Thiết lập"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Border CornerRadius="16" Background="Transparent">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#1E3324"
                               Text="{Binding PageTitle}"/>

                    <Grid Grid.Row="1" Margin="0,16,0,0">

                        <Grid Visibility="{Binding IsOverviewPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,14">
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock FontSize="11" Foreground="#5A6B57" Text="Ứng dụng hiện tại"/>
                                        <TextBlock Margin="0,6,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#1D3022" Text="{Binding CurrentAppName}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock FontSize="11" Foreground="#5A6B57" Text="Tổng thời gian theo dõi"/>
                                        <TextBlock Margin="0,6,0,0" FontSize="26" FontWeight="Bold" Foreground="#1D3022" Text="{Binding ElapsedTime}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock FontSize="11" Foreground="#5A6B57" Text="Điểm hiệu suất"/>
                                        <TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="#245F35" Text="{Binding FocusScoreText}"/>
                                        <TextBlock Margin="0,2,0,0" FontSize="12" Foreground="#2D4032" Text="{Binding FocusSummary}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,14"
                                    Visibility="{Binding HasNotification, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="14" Margin="0,0,10,0" Foreground="#1E3324" Text="Thông báo:"/>
                                    <TextBlock FontSize="14" Foreground="#1E3324" TextWrapping="Wrap" Text="{Binding Notification}"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,14,0">
                                    <StackPanel>
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#50634E" Text="Top 3 ứng dụng trong phiên hiện tại"/>
                                        <TextBlock Margin="0,8,0,0" FontSize="13" Foreground="#1D3022" Text="{Binding TopAppsSummary}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#50634E" Text="Điều khiển"/>
                                        <UniformGrid Margin="0,14,0,0" Columns="3">
                                            <Button Margin="0,0,8,0" Height="40" Command="{Binding StartCommand}" Background="#DBF1DF" BorderBrush="#BFDCC5" Foreground="#1C5030" Content="Bắt đầu"/>
                                            <Button Margin="0,0,8,0" Height="40" Command="{Binding PauseCommand}" Background="#F0EEE1" BorderBrush="#DED9C0" Foreground="#5A542A" Content="Tạm dừng"/>
                                            <Button Height="40" Command="{Binding StopCommand}" Background="#F5E1E1" BorderBrush="#E3C7C7" Foreground="#6A2E2E" Content="Dừng"/>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid Visibility="{Binding IsSessionsPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,14" VerticalAlignment="Center">
                                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                    <TextBlock VerticalAlignment="Center" FontSize="24" FontWeight="Black" Foreground="#1E3324" Text="Phiên theo dõi"/>
                                    <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                        <Border Background="#E8F1E4" CornerRadius="10" Padding="2,3">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#2E5037" Text="Dòng thời gian tuần"/>
                                        </Border>
                                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="#4A5B48" Text="{Binding WeekRangeTitle}"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <DatePicker 
                                        Style="{StaticResource ModernDatePicker}"
                                        SelectedDate="{Binding SelectedWeekDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Width="100" Height="34" Margin="0,0,8,0" Style="{StaticResource SessionActionButtonStyle}" Foreground="White" Command="{Binding RefreshSessionsCommand}" Content="Làm mới"/>
                                    <Button Width="146" Height="34" Style="{StaticResource SessionActionButtonStyle}" Background="DarkRed" BorderBrush="#D8C0C0" Foreground="White" Command="{Binding DeleteSelectedSessionCommand}" Content="Xóa mục chọn"/>
                                </StackPanel>
                            </DockPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource SessionShellStyle}" Padding="12">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <Grid>
                                            <ItemsControl ItemsSource="{Binding SessionDayGroups}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,12" Padding="10">
                                                        <StackPanel>
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#24422A" Text="{Binding DateTitle}"/>
                                                                <Border DockPanel.Dock="Right" Background="#E6EFE2" CornerRadius="8" Padding="8,2">
                                                                    <TextBlock Style="{StaticResource SessionMetaTextStyle}" FontWeight="SemiBold" Text="{Binding Sessions.Count, StringFormat={}{0} phiên}"/>
                                                                </Border>
                                                            </DockPanel>

                                                            <ItemsControl ItemsSource="{Binding Sessions}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Button Margin="0,8,0,0"
                                                                                Style="{StaticResource SessionItemButtonStyle}"
                                                                                Tag="{Binding IsSelected}"
                                                                                Command="{Binding DataContext.SelectTrackingSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="4"/>
                                                                                    <ColumnDefinition Width="8"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>

                                                                                <Border Grid.Column="0"
                                                                                        Background="#4E7F59"
                                                                                        CornerRadius="2"
                                                                                        Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                                                <StackPanel Grid.Column="2">
                                                                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1D3022" Text="{Binding TimeRange}"/>
                                                                                    <TextBlock Margin="0,2,0,0" FontSize="12" Foreground="#4B6148" Text="{Binding TopApps}" TextWrapping="Wrap"/>
                                                                                </StackPanel>

                                                                                <StackPanel Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Center">
                                                                                    <Border HorizontalAlignment="Right" Background="#EAF2E7" CornerRadius="8" Padding="8,2">
                                                                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#24422A" Text="{Binding TotalDuration}"/>
                                                                                    </Border>
                                                           
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                            <TextBlock Text="Không có dữ liệu."
                                                        FontSize="14"
                                                       Foreground="#6A7A67"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">                                  
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SessionDayGroups.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                          
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            
                                        </Grid>

                                    </ScrollViewer>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource SessionShellStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                 
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#1E3324" Text="Chi tiết phiên"/>
                                        

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,12,0,0"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1D3022"
                                                   Text="{Binding SelectedTrackingSession.SessionDateTitle}"
                                                   Visibility="{Binding HasSelectedTrackingSession, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                        <TextBlock Grid.Row="2"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="#50634E"
                                                   Text="{Binding SelectedTrackingSession.TimeRange}"
                                                   Visibility="{Binding HasSelectedTrackingSession, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                        <Grid Grid.Row="3" Margin="0,12,0,0" Visibility="{Binding HasSelectedTrackingSession, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <UniformGrid Grid.Row="0" Columns="2" Margin="0,0,0,12">
                                                <Border Margin="0,0,8,0" Background="#F1F7EE" BorderBrush="#D8E5D4" BorderThickness="1" CornerRadius="10" Padding="10,8">
                                                    <StackPanel>
                                                        <TextBlock FontSize="11" Foreground="#60715E" Text="Tổng"/>
                                                        <TextBlock Margin="0,2,0,0" FontSize="14" FontWeight="SemiBold" Foreground="#1D3022" Text="{Binding SelectedTrackingSession.TotalDuration}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="#F8F6EC" BorderBrush="#E6DDC8" BorderThickness="1" CornerRadius="10" Padding="10,8">

                                                    <StackPanel>
                                                        <TextBlock FontSize="11" Foreground="#6D6A54" Text="Không hoạt động"/>
                                                        <TextBlock Margin="0,2,0,0" FontSize="14" FontWeight="SemiBold" Foreground="#3F3A20" Text="{Binding SelectedTrackingSession.IdleDuration}"/>
                                                    </StackPanel> 
                                                </Border>
                                            </UniformGrid>

                                            <TextBlock Grid.Row="1" FontSize="16" FontWeight="SemiBold" Foreground="#24422A" Text="Chi tiết ứng dụng"/>
                                            <Border Grid.Row="2" Grid.RowSpan="2" Margin="0,8,0,0" Background="#F7FBF5" BorderBrush="#DCE6D8" BorderThickness="1" CornerRadius="10" Padding="10">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding SelectedTrackingSession.AppUsageProgressItems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="0,0,0,10">
                                                                    <DockPanel LastChildFill="False">
                                                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#24422A" Text="{Binding AppName}"/>
                                                                        <TextBlock DockPanel.Dock="Right" FontSize="11" Foreground="#536651" Text="{Binding Duration}"/>
                                                                    </DockPanel>
                                                                    <Grid Margin="0,6,0,0">
                                                                        <ProgressBar Height="8"
                                                                                     Minimum="0"
                                                                                     Maximum="100"
                                                                                     Value="{Binding Percent}"
                                                                                     Background="#E5EDE2"
                                                                                     Foreground="#4F7E59">
                                                                            <ProgressBar.Template>

                                                                                <ControlTemplate TargetType="ProgressBar">
                                                                                    <Border Background="#E5EDE2" CornerRadius="4" Height="8">
                                                                                        <Border x:Name="PART_Track" Background="#4F7E59" CornerRadius="4"/>
                                                                                    </Border>
                                                                                </ControlTemplate>
                                                                            </ProgressBar.Template>

                                                                        </ProgressBar>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="3"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="#60715E"
                                                   Text="Chọn một phiên để xem chi tiết."
                                                   Visibility="{Binding NoSelectedTrackingSession, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border Grid.Row="2" Margin="0,10,0,0" Background="#EEF4EA" BorderBrush="#D7E2D2" BorderThickness="1" CornerRadius="10" Padding="10,7">
                                <TextBlock FontSize="12" Foreground="#3F5645" Text="{Binding SessionsStatusMessage}"/>
                            </Border>
                        </Grid>

                        <Grid Visibility="{Binding IsSettingsPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Background="#F3F3F3" Padding="24" BorderBrush="#E3E8DF">
                                <StackPanel>
                                    <TextBlock FontSize="14" FontWeight="Bold" Foreground="#3E4942" Text="TÙY CHỌN THEO DÕI"/>

                                    <StackPanel Margin="0,24,0,0">
                                        <TextBlock FontSize="14" FontWeight="Medium" Foreground="#1A1C1C" Text="Phát hiện không hoạt động"/>
                                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                            <Button Width="120" Margin="0,0,10,0"
                                                    Command="{Binding SetIdleDetection5Command}"
                                                    Tag="{Binding IsIdleDetection5Selected}"
                                                    Style="{StaticResource PreferenceOptionButtonStyle}"
                                                    Content="5 phút"/>
                                            <Button Width="120"
                                                    Command="{Binding SetIdleDetection10Command}"
                                                    Tag="{Binding IsIdleDetection10Selected}"
                                                    Style="{StaticResource PreferenceOptionButtonStyle}"
                                                    Content="10 phút"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <DockPanel Margin="0,22,0,0" LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="14" Foreground="#1A1C1C" Text="Tự khởi động cùng Windows"/>
                                        <Button DockPanel.Dock="Right"
                                                Width="64"
                                                Tag="{Binding AutoStartOnBoot}"
                                                Command="{Binding ToggleAutoStartCommand}"
                                                Style="{StaticResource PreferenceToggleButtonStyle}"
                                                Content="{Binding AutoStartOnBootStateText}"/>
                                    </DockPanel>

                                    <StackPanel Margin="0,24,0,0">
                                        <DockPanel LastChildFill="False">
                                            <TextBlock DockPanel.Dock="Left" FontSize="14" Foreground="#1A1C1C" Text="Độ mờ lớp phủ"/>
                                            <TextBlock DockPanel.Dock="Right" FontSize="12" FontWeight="Bold" Foreground="#006947" Text="{Binding OverlayOpacityText}"/>
                                        </DockPanel>
                                        <Slider Margin="0,12,0,0"
                                                Minimum="10"
                                                Maximum="100"
                                                TickFrequency="5"
                                                IsSnapToTickEnabled="True"
                                                Value="{Binding OverlayOpacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Background="#F3F3F3" Padding="24" BorderBrush="#E3E8DF">
                                <StackPanel>
                                    <TextBlock FontSize="14" FontWeight="Bold" Foreground="#3E4942" Text="VỊ TRÍ LỚP PHỦ"/>
                                    <UniformGrid Margin="0,16,0,0" Columns="3" Rows="3">
                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,6,6" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsTopLeftOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.TopLeft}">
                                            <materialDesign:PackIcon Kind="ArrowTopLeft" Width="18" Height="18"/>
                                        </RadioButton>
                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,6,6" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsTopCenterOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.TopCenter}">

                                        <materialDesign:PackIcon Kind="ArrowTop" Width="18" Height="18"/>
                                        </RadioButton>


                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,0,6" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsTopRightOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.TopRight}">
                                        <materialDesign:PackIcon Kind="ArrowTopRight" Width="18" Height="18"/>
                                        </RadioButton>
                                        

                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,6,6" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsMiddleLeftOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.MiddleLeft}">
                                        <materialDesign:PackIcon Kind="ArrowLeft" Width="18" Height="18"/>
                                        </RadioButton>


                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,6,6" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsCenterOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.Center}">
                                            <materialDesign:PackIcon Kind="Dot" Width="40" Height="40"/>
                                        </RadioButton>
                                        
                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,0,6" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsMiddleRightOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.MiddleRight}">
                                            <materialDesign:PackIcon Kind="ArrowRight" Width="18" Height="18"/>
                                        </RadioButton>
                                        
                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,6,0" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsBottomLeftOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.BottomLeft}">
                                            <materialDesign:PackIcon Kind="ArrowBottomLeft" Width="18" Height="18"/>
                                        </RadioButton>

                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,6,0" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsBottomCenterOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.BottomCenter}">
                                            <materialDesign:PackIcon Kind="ArrowBottom" Width="18" Height="18"/>
                                        </RadioButton>

                                        <RadioButton GroupName="OverlayPositionGrid" Margin="0,0,0,0" Style="{StaticResource OverlayAnchorButtonStyle}" IsChecked="{Binding IsBottomRightOverlay, Mode=OneWay}" Command="{Binding SetOverlayPositionCommand}" CommandParameter="{x:Static vm:OverlayAnchor.BottomRight}">
                                            <materialDesign:PackIcon Kind="ArrowBottomRight" Width="18" Height="18"/>
                                        </RadioButton>
                                    </UniformGrid>

                                    <Border Margin="0,18,0,0" Background="#FFFFFF" BorderBrush="#DCE6D8" BorderThickness="1" CornerRadius="10" Padding="12">
                                        <StackPanel>
                                            <TextBlock FontSize="12" Foreground="#5F6F64" Text="Xem trước"/>
                                            <TextBlock Margin="0,6,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#1E3324" Text="Đã cập nhật độ mờ và vị trí lớp phủ."/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
