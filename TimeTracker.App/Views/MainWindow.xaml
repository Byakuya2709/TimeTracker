<Window x:Class="TimeTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:TimeTracker.App.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TimeTracker"
        Icon="pack://application:,,,/TimeTracker;component/Resources/logo.png"
        Width="1240"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        FontFamily="pack://application:,,,/TimeTracker;component/Resources/Assets/Fonts/#Inter"
        Background="#F5F5F5">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="252"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1F3724">
            <Grid Margin="18,24,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="#F3FAEF" Text="Time Tracker"/>
                    <TextBlock Margin="0,4,0,0" FontSize="12" TextWrapping="Wrap" Foreground="#C9DFC6" Text="Bảng điều khiển theo dõi thời gian làm việc"/>
                </StackPanel>

                
                <StackPanel Grid.Row="1" Margin="0,30,0,0">
                    <RadioButton GroupName="SidebarTabs"
                                 Margin="0,0,0,10"
                                 IsChecked="{Binding IsOverviewPage, Mode=OneWay}"
                                 Command="{Binding ShowOverviewCommand}"
                                 Style="{StaticResource SideBarButtonStyle}">

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon 
                            Kind="Home"
                            Width="18"
                            Height="18"
                            Margin="0,0,8,0"
                            Foreground="White"/>

                            <TextBlock 
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="#F3FAEF"
                                Text="Tổng quan"/>
                        </StackPanel>

                    </RadioButton>

                    <RadioButton GroupName="SidebarTabs"
                                 Margin="0,0,0,10"
                                 IsChecked="{Binding IsSessionsPage, Mode=OneWay}"
                                 Command="{Binding ShowSessionsCommand}"
                                 Style="{StaticResource SideBarButtonStyle}">


                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon 
                                    Kind="History"
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    Foreground="White"/>

                            <TextBlock 
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="#F3FAEF"
                                Text="Lịch sử"/>
                        </StackPanel>

                    </RadioButton>

                    <RadioButton GroupName="SidebarTabs"
                                 IsChecked="{Binding IsSettingsPage, Mode=OneWay}"
                                 Command="{Binding ShowSettingsCommand}"
                                 Style="{StaticResource SideBarButtonStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon 
                     Kind="Settings"
                     Width="18"
                     Height="18"
                     Margin="0,0,8,0"
                     Foreground="White"/>

                            <TextBlock 
                 FontSize="16"
                 FontWeight="SemiBold"
                 Foreground="#F3FAEF"
                 Text="Thiết lập"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Border CornerRadius="16" Background="Transparent">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock 
                        VerticalAlignment="Center"
                        FontSize="24" FontWeight="Black" 
                        Foreground="#1E3324" 
                        Text="{Binding PageTitle}"/>


                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <views:OverviewPage/>
                        <views:SessionsPage/>
                        <views:SettingsPage/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
