<Window x:Class="TimeTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Time Tracker Overlay"
        Width="260"
        Height="240"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="20"
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            Background="#CCF5F7F6"
            MouseLeftButtonDown="OverlayBorder_MouseLeftButtonDown">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="10,8"
                    CornerRadius="12"
                    Background="#55FFFFFF"
                    BorderBrush="#22000000"
                    BorderThickness="0,0,0,1">
                <TextBlock FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1A1C1C"
                           Text="{Binding CurrentAppName}" />
            </Border>

            <StackPanel Grid.Row="1" Margin="0,14,0,0" HorizontalAlignment="Center">
                <TextBlock FontSize="34"
                           FontWeight="Light"
                           Foreground="#1A1C1C"
                           Text="{Binding ElapsedTime}" />
                <TextBlock FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#3E4942"
                           HorizontalAlignment="Center"
                           Text="ELAPSED TIME" />
            </StackPanel>

            <Border Grid.Row="2"
                    Margin="0,14,0,0"
                    Padding="12"
                    CornerRadius="14"
                    Background="#66FFFFFF"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="52"
                            Height="52"
                            CornerRadius="26"
                            BorderBrush="#006947"
                            BorderThickness="2"
                            Background="#22FFFFFF">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#006947"
                                   Text="{Binding FocusScoreText}" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="10"
                                   FontWeight="Medium"
                                   Foreground="#3E4942"
                                   Text="FOCUS SCORE" />
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1C1C"
                                   Text="{Binding FocusSummary}" />
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
