<Window x:Class="TimeTracker.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Time Tracker Overlay"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="1"
                Grid.Column="1"
                CornerRadius="20"
                BorderBrush="#44FFFFFF"
                BorderThickness="1"
                Background="#CCF5F7F6"
                VerticalAlignment="Top"
                Width="260"
                Margin="0,8,0,0"
                Visibility="{Binding HasNotification, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Grid Margin="16,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Path Grid.Column="0"
                      Data="M8,0 A8,8 0 1,0 8,16 A8,8 0 1,0 8,0 Z M7.2,4 L8.8,4 L8.8,9 L7.2,9 L7.2,4 Z M7.2,10 L8.8,10 L8.8,11.6 L7.2,11.6 L7.2,10 Z"
                      Fill="#1A1C1C"
                      Width="16"
                      Height="16"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"/>

                <TextBlock Grid.Column="1"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1A1C1C"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Padding="0,10"
                           Text="{Binding Notification}"/>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Width="260"
                Height="Auto"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                CornerRadius="20"
                BorderBrush="#44FFFFFF"
                BorderThickness="1"
                Background="#CCF5F7F6"
                MouseLeftButtonDown="OverlayBorder_MouseLeftButtonDown">

            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="10,8"
                        CornerRadius="12"
                        Background="#55FFFFFF"
                        BorderBrush="#22000000"
                        BorderThickness="0,0,0,1">
                    <TextBlock FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1A1C1C"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Text="{Binding CurrentAppName}"/>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,14,0,0" HorizontalAlignment="Center">
                    <TextBlock FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="#1A1C1C"
                               Text="{Binding ElapsedTime}"/>
                    <TextBlock FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#3E4942"
                               HorizontalAlignment="Center"
                               Text="TOTAL RECORDING"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Margin="0,14,0,0"
                        Padding="12"
                        CornerRadius="14"
                        Background="#66FFFFFF"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="52"
                                Height="52"
                                CornerRadius="26"
                                BorderBrush="#006947"
                                BorderThickness="2"
                                Background="#22FFFFFF">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#006947"
                                       Text="{Binding FocusScoreText}"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="10"
                                       FontWeight="Medium"
                                       Foreground="#3E4942"
                                       Text="FOCUS SCORE"/>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1C1C"
                                       Text="{Binding FocusSummary}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Margin="0,12,0,0"
                        Padding="10,8"
                        CornerRadius="12"
                        Background="#4DFFFFFF"
                        BorderBrush="#22000000"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#3E4942"
                                   Text="TOP 3 APPS"/>
                        <TextBlock Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="#1A1C1C"
                                   Text="{Binding TopAppsSummary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        Margin="0,12,0,0"
                        BorderBrush="#33000000"
                        BorderThickness="0,0.3,0,0">
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <RadioButton Grid.Column="0"
                                     GroupName="PlayerControls"
                                     IsChecked="{Binding IsRecording, Mode=OneWay}"
                                     Command="{Binding StartCommand}"
                                     Style="{StaticResource ControlButtonStyle}">
                            <Viewbox Width="14" Height="14">
                                <Path Style="{StaticResource IconPathStyle}" Data="M2,0 L12,7 L2,14 Z"/>
                            </Viewbox>
                        </RadioButton>

                        <RadioButton Grid.Column="1"
                                     GroupName="PlayerControls"
                                     IsChecked="{Binding IsPaused, Mode=OneWay}"
                                     Command="{Binding PauseCommand}"
                                     Style="{StaticResource ControlButtonStyle}">
                            <Viewbox Width="14" Height="14">
                                <Path Style="{StaticResource IconPathStyle}" Data="M1,0 L5,0 L5,14 L1,14 Z M9,0 L13,0 L13,14 L9,14 Z"/>
                            </Viewbox>
                        </RadioButton>

                        <RadioButton Grid.Column="2"
                                     GroupName="PlayerControls"
                                     IsChecked="{Binding IsStopped, Mode=OneWay}"
                                     Command="{Binding StopCommand}"
                                     Style="{StaticResource ControlButtonStyle}">
                            <Viewbox Width="14" Height="14">
                                <Path Style="{StaticResource IconPathStyle}" Data="M2,2 L12,2 L12,12 L2,12 Z"/>
                            </Viewbox>
                        </RadioButton>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
