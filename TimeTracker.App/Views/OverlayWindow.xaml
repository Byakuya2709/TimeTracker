<Window x:Class="TimeTracker.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Lớp phủ TimeTracker"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Opacity="{Binding OverlayOpacityRatio}"
        AllowsTransparency="True"
        Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="1"
                Grid.Column="1"
                CornerRadius="20"
                BorderBrush="#44FFFFFF"
                BorderThickness="1"
                Background="#CCF5F7F6"
                VerticalAlignment="Top"
                Width="260"
                Margin="0,8,0,0"
                Visibility="{Binding HasNotification, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Grid Margin="16,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>


                <Grid VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Badge" Width="22" Height="22"/>
                </Grid>


                <TextBlock Grid.Column="1"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1A1C1C"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Padding="0,10"
                           Text="{Binding Notification}"/>
            </Grid>
        </Border>


        <Border Grid.Row="1"
                Grid.Column="1"
                CornerRadius="20"
                BorderBrush="#44FFFFFF"
                BorderThickness="1"
                Background="#CCF5F7F6"
                VerticalAlignment="Top"
                Width="260"
                Margin="0,8,0,0"
                Visibility="{Binding IsStopped, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Grid Margin="16,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>


                <Grid VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Badge" Width="22" Height="22" Margin="0,0,8,0"/>
                </Grid>


                <TextBlock Grid.Column="1"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#1A1C1C"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Padding="0,10"
                           Text="Bộ đếm sẽ có đỗ trễ từ 2-5s vì lí do tối ưu hiệu năng."/>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Width="260"
                Height="Auto"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                CornerRadius="20"
                BorderBrush="#44FFFFFF"
                BorderThickness="1"
                Background="#CCF5F7F6"
                MouseLeftButtonDown="OverlayBorder_MouseLeftButtonDown">

            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ClipToBounds="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="9*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="10,8"
                            CornerRadius="12"
                            Background="#55FFFFFF"
                            BorderBrush="#22000000"
                            BorderThickness="0,0,0,1">
                        <TextBlock FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#1A1C1C"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Text="{Binding CurrentAppName}"/>
                    </Border>

                    <Button Grid.Column="1"
                            Height="24"
                            Background="#F1D9D9"
                            BorderBrush="#D4B2B2"
                            Foreground="#6A2E2E"
                            Content="x"
                            Margin="8,5,-8,5"
                            FontWeight="Bold"
                            Panel.ZIndex="10"
                            Click="ExitAppButton_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <ContentPresenter 
                                        x:Name="content"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>

                                    <!-- hover -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="DarkRed"/>
                                        <Setter TargetName="content"
                                                Property="TextElement.Foreground"
                                                Value="White"/>
                                    </Trigger>

                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                </Grid>


                <StackPanel Grid.Row="1" Margin="0,14,0,0" HorizontalAlignment="Center">
                    <TextBlock FontSize="34"
                               FontWeight="SemiBold"
                               Foreground="#1A1C1C"
                               Text="{Binding ElapsedTime}"/>
                    <TextBlock FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#3E4942"
                               HorizontalAlignment="Center"
                               Text="TỔNG THỜI GIAN THEO DÕI"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Margin="0,14,0,0"
                        Padding="12"
                        CornerRadius="14"
                        Background="#66FFFFFF"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="52"
                                Height="52"
                                CornerRadius="26"
                                BorderBrush="#006947"
                                BorderThickness="2"
                                Background="#22FFFFFF">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#006947"
                                       Text="{Binding FocusScoreText}"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="10"
                                       FontWeight="Medium"
                                       Foreground="#3E4942"
                                       Text="ĐIỂM HIỆU SUẤT"/>
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1C1C"
                                       Text="{Binding FocusSummary}"/>
                        </StackPanel>
                    </Grid>
                </Border>


                <Border Grid.Row="4"
                        Margin="0,12,0,0"
                        BorderBrush="#33000000"
                        BorderThickness="0,0.3,0,0">
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <RadioButton Grid.Column="0"
                                     GroupName="PlayerControls"
                                     IsChecked="{Binding IsRecording, Mode=OneWay}"
                                     Command="{Binding StartCommand}"
                                     Style="{StaticResource ControlButtonStyle}"
                                     >
                            <Viewbox Width="14" Height="14" Visibility="{Binding ShowPlayIcon, Converter={StaticResource BooleanToVisibilityConverter}}"  >
                                <Path Style="{StaticResource IconPathStyle}" Data="M2,0 L12,7 L2,14 Z"/>
                            </Viewbox>
                        </RadioButton>
                        <Border Grid.Column="0" Background="#22006947" CornerRadius="10" 
                                Visibility="{Binding IsPaused, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 IsHitTestVisible="False">

                        </Border>

                        <RadioButton Grid.Column="0"
                                     GroupName="PlayerControls"
                                     IsChecked="{Binding IsPaused, Mode=OneWay}"
                                     Command="{Binding PauseCommand}"
                                     Style="{StaticResource ControlButtonStyle}"
                                      Visibility="{Binding IsRecording, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     >
                            <Viewbox Width="14" Height="14">
                                <Path Style="{StaticResource IconPathStyle}" Data="M1,0 L5,0 L5,14 L1,14 Z M9,0 L13,0 L13,14 L9,14 Z"/>
                            </Viewbox>
                        </RadioButton>

                        <RadioButton Grid.Column="1"
                                     GroupName="PlayerControls"
                                     IsChecked="{Binding IsStopped, Mode=OneWay}"
                                     Command="{Binding StopCommand}"
                                     Style="{StaticResource ControlButtonStyle}">
                            <Viewbox Width="14" Height="14">
                                <Path Style="{StaticResource IconPathStyle}" Data="M2,2 L12,2 L12,12 L2,12 Z"/>
                            </Viewbox>
                        </RadioButton>

                        <Button Grid.Column="2"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="OpenMainWindowButton_Click">

                            <Viewbox Width="18" Height="18">
                                <materialDesign:PackIcon Kind="Settings" Width="22" Height="22"/>
                            </Viewbox>

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg"
                                                    Background="Transparent"
                                                    CornerRadius="4">

                                                    <ContentPresenter 
                                                            HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>

                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg"
                                                                Property="Background"
                                                                Value="#11006947"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>

                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>

                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
