<UserControl x:Class="TimeTracker.App.Views.OverviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:TimeTracker.App.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
<Grid Visibility="{Binding IsOverviewPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#2B4634"
                                    CornerRadius="16"
                                    Padding="32"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="6" Opacity="0.15" Color="#1E3324"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontSize="26" FontWeight="Black" Foreground="#FFFFFF" Text="Chào mừng đến với Time Tracker"/>
                                        <TextBlock Margin="0,12,0,0"
                                                   FontSize="14"
                                                   Foreground="#D1E8D5"
                                                   LineHeight="22"
                                                   TextWrapping="Wrap"
                                                   Text="Ứng dụng tự động ghi nhận thời gian làm việc, giám sát hoạt động trên máy tính và hiển thị tiến độ trực quan ngay trên Overlay. Giải pháp tối ưu để nâng cao hiệu suất làm việc mà không làm gián đoạn sự tập trung thiết yếu của bạn."/>

                                        <WrapPanel Margin="0,20,0,0">
                                            <Border Margin="0,0,12,8" Background="#41664C" CornerRadius="8" Padding="12,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="TimerOutline" Width="16" Height="16" Foreground="#A9D0B2" VerticalAlignment="Center"/>
                                                    <TextBlock Margin="6,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#F5F9F6" VerticalAlignment="Center" Text="Theo dõi theo phiên"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="0,0,12,8" Background="OrangeRed" CornerRadius="8" Padding="12,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Sleep" Width="16" Height="16" Foreground="#A9D0B2" VerticalAlignment="Center"/>
                                                    <TextBlock Margin="6,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#F5F9F6" VerticalAlignment="Center" Text="Một số app không hoạt động"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="0,0,0,8" Background="CadetBlue" CornerRadius="8" Padding="12,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="LayersOutline" Width="16" Height="16" Foreground="#A9D0B2" VerticalAlignment="Center"/>
                                                    <TextBlock Margin="6,0,0,0" FontSize="13" FontWeight="SemiBold" Foreground="#F5F9F6" VerticalAlignment="Center" Text="Tùy biến Overlay linh hoạt"/>
                                                </StackPanel>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                    
                                    <materialDesign:PackIcon Grid.Column="1" Kind="ChartDonutVariant" Width="110" Height="110" Foreground="#3F664A" VerticalAlignment="Center" Margin="30,0,10,0"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#FFFFFF"
                                        CornerRadius="16"
                                        Padding="28"
                                        VerticalAlignment="Stretch">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="25" ShadowDepth="4" Opacity="0.04" Color="Black"/>
                                    </Border.Effect>
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,24">
                                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="Black" Text="Hướng dẫn sử dụng nhanh"/>
                                            <TextBlock Margin="0,6,0,0" FontSize="13" Foreground="#6C8069" Text="Chỉ 4 bước đơn giản để làm chủ quỹ thời gian làm việc của bạn."/>
                                        </StackPanel>

                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <!-- Step 1 -->
                                                <Grid Margin="0,0,0,24">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="36" Height="36" Background="#E8F1E4" CornerRadius="18" VerticalAlignment="Top">
                                                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="#2E5037" HorizontalAlignment="Center" VerticalAlignment="Center" Text="1"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                        <TextBlock FontSize="15" FontWeight="Bold" Foreground="#2A4A31" Text="Mở ứng dụng và để chạy nền"/>
                                                        <TextBlock Margin="0,6,0,0" FontSize="13" Foreground="#5A6E57" LineHeight="20" TextWrapping="Wrap" Text="Ứng dụng sẽ tự động ghi nhận hoạt động mỗi khi bạn làm việc trên máy tính. Giao diện Overlay sẽ xuất hiện trên màn hình."/>
                                                    </StackPanel>
                                                </Grid>
                                                
                                                <!-- Step 2 -->
                                                <Grid Margin="0,0,0,24">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="36" Height="36" Background="#E8F1E4" CornerRadius="18" VerticalAlignment="Top">
                                                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="#2E5037" HorizontalAlignment="Center" VerticalAlignment="Center" Text="2"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                        <TextBlock FontSize="15" FontWeight="Bold" Foreground="#2A4A31" Text="Theo dõi lịch sử phiên"/>
                                                        <TextBlock Margin="0,6,0,0" FontSize="13" Foreground="#5A6E57" LineHeight="20" TextWrapping="Wrap" Text="Truy cập tab Lịch sử để kiểm tra thông tin thống kê theo ngày, tổng thời lượng làm việc và ứng dụng nào được dùng nhiều nhất."/>
                                                    </StackPanel>
                                                </Grid>
                                                
                                                <!-- Step 3 -->
                                                <Grid Margin="0,0,0,24">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="36" Height="36" Background="#E8F1E4" CornerRadius="18" VerticalAlignment="Top">
                                                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="#2E5037" HorizontalAlignment="Center" VerticalAlignment="Center" Text="3"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                        <TextBlock FontSize="15" FontWeight="Bold" Foreground="#2A4A31" Text="Nhấn vào phiên để xem chi tiết"/>
                                                        <TextBlock Margin="0,6,0,0" FontSize="13" Foreground="#5A6E57" LineHeight="20" TextWrapping="Wrap" Text="Xem lại phần 'breakdown' phân tách cụ thể bạn đã tiêu tốn bao nhiêu thời gian vào từng ứng dụng."/>
                                                    </StackPanel>
                                                </Grid>
                                                
                                                <!-- Step 4 -->
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="36" Height="36" Background="#E8F1E4" CornerRadius="18" VerticalAlignment="Top">
                                                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="#2E5037" HorizontalAlignment="Center" VerticalAlignment="Center" Text="4"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                        <TextBlock FontSize="15" FontWeight="Bold" Foreground="#2A4A31" Text="Cá nhân hóa thiết lập"/>
                                                        <TextBlock Margin="0,6,0,0" FontSize="13" Foreground="#5A6E57" LineHeight="20" TextWrapping="Wrap" Text="Vào tab Thiết lập nếu bạn cần căn chỉnh thời gian không hoạt động, hay đổi vị trí và độ mờ của Overlay sao cho thuận tiện."/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>

                                <Border Grid.Column="2" VerticalAlignment="Stretch">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="16"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Tips -->
                                            <Border Grid.Row="0"
                                                    Background="#EEF6EA"
                                                    BorderBrush="#D7EFD2"
                                                    BorderThickness="1"
                                                    CornerRadius="16"
                                                    Padding="24">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.03" Color="Black"/>
                                                </Border.Effect>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                        <materialDesign:PackIcon Kind="LightbulbOn10" Width="22" Height="22" Foreground="#D48806" VerticalAlignment="Center"/>
                                                        <TextBlock Margin="8,0,0,0" FontSize="16" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center" Text="Mẹo hữu ích"/>
                                                    </StackPanel>

                                                    <Grid Margin="0,0,0,16">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <materialDesign:PackIcon Grid.Column="0" Kind="CheckCircleOutline" Width="18" Height="18" Foreground="#518E60" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="13" Foreground="#1E3324" TextWrapping="Wrap" LineHeight="20" Text="Chọn ngưỡng không hoạt động 5 phút cho công việc cá nhân cần độ tập trung cao."/>
                                                    </Grid>

                                                    <Grid Margin="0,0,0,16">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <materialDesign:PackIcon Grid.Column="0" Kind="CheckCircleOutline" Width="18" Height="18" Foreground="#518E60" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="13" Foreground="#1E3324" TextWrapping="Wrap" LineHeight="20" Text="Di chuyển Overlay ra các góc ít thao tác để quan sát tiến độ một cách tinh tế."/>
                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <materialDesign:PackIcon Grid.Column="0" Kind="CheckCircleOutline" Width="18" Height="18" Foreground="#518E60" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" FontSize="13" Foreground="#1E3324" TextWrapping="Wrap" LineHeight="20" Text="Dùng tính năng Làm mới ở mục Lịch sử để cập nhật số liệu mới nhất ngay tức thì."/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Dictionary -->
                                            <Border Grid.Row="2"
                                                    Background="#FFFFFF"
                                                    BorderBrush="#EADFD6"
                                                    BorderThickness="1"
                                                    CornerRadius="16"
                                                    Padding="24">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.02" Color="Black"/>
                                                </Border.Effect>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                                        <materialDesign:PackIcon Kind="Translate" Width="20" Height="20" Foreground="#788C7E" VerticalAlignment="Center"/>
                                                        <TextBlock Margin="8,0,0,0" FontSize="15" FontWeight="Bold" Foreground="#3E4942" VerticalAlignment="Center" Text="Thuật ngữ quen thuộc"/>
                                                    </StackPanel>

                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="Black" Text="Overlay" Width="80"/>
                                                        <TextBlock Grid.Column="1" FontSize="13" Foreground="Gray" TextWrapping="Wrap" Text="Lớp phủ hiển thị nổi trên màn hình."/>
                                                    </Grid>

                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="Black" Text="Tab" Width="80"/>
                                                        <TextBlock Grid.Column="1" FontSize="13" Foreground="Gray" TextWrapping="Wrap" Text="Thẻ chức năng ở thanh điều hướng."/>
                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="Black" Text="Breakdown" Width="80"/>
                                                        <TextBlock Grid.Column="1" FontSize="13" Foreground="Gray" TextWrapping="Wrap" Text="Sự phân tách tỷ lệ thời gian giữa các ứng dụng."/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>

                        
</UserControl>
